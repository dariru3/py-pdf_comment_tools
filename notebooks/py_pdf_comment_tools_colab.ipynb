 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "title"
   },
   "source": [
    "# PDF Comment Tools in Google Colab\n",
    "\n",
    "This notebook installs `py-pdf_comment_tools` from GitHub and gives you a simple single-PDF workflow for:\n",
    "\n",
    "- `highlight-keywords`: upload one PDF and one keywords CSV, then download the annotated PDF and summary CSV\n",
    "- `extract-comments`: upload one annotated PDF, then download the extracted comments CSV\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "setup-notes"
   },
   "source": [
    "## Setup\n",
    "\n",
    "Run the next two cells once per Colab session. It clones the repo into `/content/py-pdf_comment_tools`, installs the package, and prepares input/output folders."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "setup"
   },
   "outputs": [],
   "source": [
    "# @title 1. Set up the notebook { display-mode: \"form\" }\n",
    "from pathlib import Path\n",
    "import shutil\n",
    "import subprocess\n",
    "import sys\n",
    "\n",
    "REPO_OWNER = \"dariru3\"\n",
    "REPO_NAME = \"py-pdf_comment_tools\"\n",
    "REPO_URL = f\"https://github.com/{REPO_OWNER}/{REPO_NAME}.git\"\n",
    "REPO_REF = \"main\"\n",
    "REPO_DIR = Path(\"/content/py-pdf_comment_tools\")\n",
    "WORK_DIR = Path(\"/content/work\")\n",
    "INPUT_DIR = WORK_DIR / \"inputs\"\n",
    "OUTPUT_DIR = WORK_DIR / \"outputs\"\n",
    "\n",
    "if REPO_DIR.exists():\n",
    "    shutil.rmtree(REPO_DIR)\n",
    "\n",
    "subprocess.run([\"git\", \"clone\", \"--branch\", REPO_REF, REPO_URL, str(REPO_DIR)], check=True)\n",
    "subprocess.run([sys.executable, \"-m\", \"pip\", \"install\", \"-q\", \"--upgrade\", \"pip\"], check=True)\n",
    "subprocess.run([sys.executable, \"-m\", \"pip\", \"install\", \"-q\", \"-e\", str(REPO_DIR)], check=True)\n",
    "\n",
    "for path in (INPUT_DIR, OUTPUT_DIR):\n",
    "    path.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "print(f\"Repo ready at {REPO_DIR} from {REPO_REF}\")\n",
    "print(f\"Inputs: {INPUT_DIR}\")\n",
    "print(f\"Outputs: {OUTPUT_DIR}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "imports"
   },
   "outputs": [],
   "source": [
    "# @title 2. Load notebook helpers { display-mode: \"form\" }\n",
    "from pathlib import Path\n",
    "import subprocess\n",
    "import sys\n",
    "\n",
    "from google.colab import files\n",
    "\n",
    "REPO_DIR = globals().get(\"REPO_DIR\", Path(\"/content/py-pdf_comment_tools\"))\n",
    "SRC_DIR = REPO_DIR / \"src\"\n",
    "if SRC_DIR.exists() and str(SRC_DIR) not in sys.path:\n",
    "    sys.path.insert(0, str(SRC_DIR))\n",
    "\n",
    "try:\n",
    "    from pdf_comment_tools import (\n",
    "        DEFAULT_COMMENTS_OUTPUT,\n",
    "        DEFAULT_SUMMARY_NAME,\n",
        "        default_annotated_pdf_path,\n",
    "        highlight_keywords,\n",
    "        load_keywords,\n",
    "        parse_pages,\n",
    "        run_extract_comments,\n",
    "    )\n",
    "except ModuleNotFoundError as exc:\n",
    "    if not REPO_DIR.exists():\n",
    "        raise RuntimeError(\n",
    "            \"Package not installed. Run the setup cell first so the repo is cloned and installed.\"\n",
    "        ) from exc\n",
    "\n",
    "    subprocess.run([sys.executable, \"-m\", \"pip\", \"install\", \"-q\", \"-e\", str(REPO_DIR)], check=True)\n",
    "    from pdf_comment_tools import (\n",
    "        DEFAULT_COMMENTS_OUTPUT,\n",
    "        DEFAULT_SUMMARY_NAME,\n",
    "        default_annotated_pdf_path,\n",
    "        highlight_keywords,\n",
    "        load_keywords,\n",
    "        parse_pages,\n",
    "        run_extract_comments,\n",
    "    )\n",
    "\n",
    "def reset_directory(path):\n",
    "    path.mkdir(parents=True, exist_ok=True)\n",
    "    for child in path.iterdir():\n",
    "        if child.is_file():\n",
    "            child.unlink()\n",
    "\n",
    "def upload_to(directory):\n",
    "    directory.mkdir(parents=True, exist_ok=True)\n",
    "    uploaded = files.upload()\n",
    "    saved = []\n",
    "    for name, data in uploaded.items():\n",
    "        target = directory / Path(name).name\n",
    "        target.write_bytes(data)\n",
    "        saved.append(target)\n",
    "    return saved\n",
    "\n",
    "def require_uploaded_file(paths, suffix, label):\n",
    "    match = next((path for path in paths if path.suffix.lower() == suffix), None)\n",
    "    if match is None:\n",
    "        raise ValueError(f\"Missing {label}. Upload a file ending in {suffix} and rerun the cell.\")\n",
    "    return match\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "workflow-section"
   },
   "source": [
    "## Choose a mode, upload files, and run",
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "workflow-config"
   },
   "outputs": [],
   "source": [
    "# @title 3. Choose mode and upload files { display-mode: \"form\" }\n",
    "selected_mode = \"Highlight Keywords\"  # @param [\"Highlight Keywords\", \"Extract Comments\"]\n",
    "\n",
    "reset_directory(INPUT_DIR)\n",
    "reset_directory(OUTPUT_DIR)\n",
    "\n",
    "print(f\"Selected mode: {selected_mode}\")\n",
    "print(\"Upload your files when prompted.\")\n",
    "uploaded_paths = upload_to(INPUT_DIR)\n",
    "\n",
    "if not uploaded_paths:\n",
    "    raise ValueError(\"No files were uploaded. Upload the required files and rerun the cell.\")\n",
    "\n",
    "print(\"Uploaded:\")\n",
    "for path in uploaded_paths:\n",
    "    print(\" -\", path.name)\n",
    "\n",
    "pdf_path = require_uploaded_file(uploaded_paths, \".pdf\", \"PDF\")\n",
    "keywords_csv = None\n",
    "\n",
    "if selected_mode == \"Highlight Keywords\":\n",
    "    keywords_csv = require_uploaded_file(uploaded_paths, \".csv\", \"keywords CSV\")\n",
    "    print(f\"Ready to highlight {pdf_path.name} using {keywords_csv.name}\")\n",
    "else:\n",
    "    print(f\"Ready to extract comments from {pdf_path.name}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "workflow-run"
   },
   "outputs": [],
   "source": [
    "# @title 4. Process files and download outputs { display-mode: \"form\" }\n",
    "pages = None\n",
    "\n",
    "if selected_mode == \"Highlight Keywords\":\n",
    "    if keywords_csv is None:\n",
    "        raise ValueError(\n",
    "            \"Keywords CSV is missing for Highlight Keywords mode. Rerun the upload cell after selecting the mode.\"\n",
    "        )\n",
    "    keywords = load_keywords(str(keywords_csv))\n",
    "    summary_path = OUTPUT_DIR / DEFAULT_SUMMARY_NAME\n",
    "    highlight_keywords(\n",
    "        pdf_paths=[pdf_path],\n",
    "        keywords=keywords,\n",
    "        pages=pages,\n",
    "        output_dir=OUTPUT_DIR,\n",
    "        summary_path=summary_path,\n",
    "    )\n",
    "\n",
    "    annotated_pdf = default_annotated_pdf_path(pdf_path, OUTPUT_DIR)\n",
    "    print(f\"Annotated PDF: {annotated_pdf}\")\n",
    "    print(f\"Summary CSV: {summary_path}\")\n",
    "    files.download(str(annotated_pdf))\n",
    "    files.download(str(summary_path))\n",
    "elif selected_mode == \"Extract Comments\":\n",
    "    output_csv = OUTPUT_DIR / DEFAULT_COMMENTS_OUTPUT\n",
    "    rows = run_extract_comments(pdf_path, pages, output_csv)\n",
    "    print(f\"Extracted {len(rows)} rows\")\n",
    "    if rows:\n",
    "        files.download(str(output_csv))\n",
    "else:\n",
    "    raise ValueError(f\"Unsupported mode: {selected_mode}\")\n"
   ]
  }
 ],
